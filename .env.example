# =============================================================================
# AidLink Frontend - Environment Configuration
# =============================================================================
# All NEXT_PUBLIC_* variables are exposed to the browser at build time.
# Restart the dev server after changing any of these values.
# =============================================================================

# --- Stellar Horizon URLs ---------------------------------------------------
# REST API endpoints for querying account data, transactions, and ledger state.
# Change these if you run a custom Horizon instance or a local Quickstart image.
NEXT_PUBLIC_HORIZON_MAINNET=https://horizon.stellar.org
NEXT_PUBLIC_HORIZON_TESTNET=https://horizon-testnet.stellar.org
NEXT_PUBLIC_HORIZON_FUTURENET=https://horizon-futurenet.stellar.org
NEXT_PUBLIC_HORIZON_STANDALONE=http://localhost:8000

# --- Soroban RPC URLs -------------------------------------------------------
# RPC endpoints for Soroban smart contract interactions.
# Must point to the network your contracts are deployed on.
NEXT_PUBLIC_SOROBAN_RPC_MAINNET=https://rpc.mainnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_TESTNET=https://soroban-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_FUTURENET=https://rpc-futurenet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_STANDALONE=http://localhost:8000/soroban/rpc

# --- Network Selection ------------------------------------------------------
# Default target network  (mainnet | testnet | futurenet | standalone)
NEXT_PUBLIC_DEFAULT_NETWORK=testnet
# Comma-separated list of networks the UI should offer
NEXT_PUBLIC_SUPPORTED_NETWORKS=testnet,futurenet

# --- Soroban Contract IDs ---------------------------------------------------
# Deploy your contracts on the chosen Soroban network and paste the IDs below.
NEXT_PUBLIC_AID_TOKEN_CONTRACT=
NEXT_PUBLIC_CAMPAIGN_MANAGER_CONTRACT=
NEXT_PUBLIC_BENEFICIARY_REGISTRY_CONTRACT=

# --- Backend API ------------------------------------------------------------
# Base URL for the off-chain backend API (user profiles, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- Feature Flags ----------------------------------------------------------
# Toggle optional features on or off without redeploying.
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true
